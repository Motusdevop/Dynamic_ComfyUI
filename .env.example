APP_ENV=prod
API_PORT=8000
DATABASE_URL=sqlite+aiosqlite:////app/data/dynamiccomfy.db

# Set a long random value in production.
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Returned in workspace_url: http://SERVER_PUBLIC_HOST:<allocated_port>
SERVER_PUBLIC_HOST=127.0.0.1

# ComfyUI image for per-user containers.
COMFY_BASE_IMAGE=dynamiccomfy/comfyui:cuda12.1
COMFY_INTERNAL_PORT=8188
ENABLE_GPU=false

# Host ports used for user containers.
PORT_RANGE_START=8101
PORT_RANGE_END=8199
