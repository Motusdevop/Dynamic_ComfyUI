# Absolute path to this repository on the server.
# Example: /opt/dynamiccomfy
PROJECT_ROOT=/opt/dynamiccomfy

# Public host (IP or domain) used in workspace_url returned by API.
SERVER_PUBLIC_HOST=127.0.0.1

# API port published by docker compose.
API_PORT=8000

# Required: set a long random secret in production.
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

APP_ENV=prod
DATABASE_URL=sqlite+aiosqlite:////app/data/dynamiccomfy.db

# Base image for user ComfyUI instances.
COMFY_BASE_IMAGE=dynamiccomfy/comfyui:cuda12.1
COMFY_INTERNAL_PORT=8188
COMFY_CONTAINER_MODELS_DIR=/opt/ComfyUI/models
COMFY_CONTAINER_OUTPUT_DIR=/opt/ComfyUI/output

# true only if server has nvidia-container-runtime configured.
ENABLE_GPU=false

AUTO_KILL_MAX_SECONDS=3600
AUTO_KILL_INTERVAL_SECONDS=600
PORT_RANGE_START=8101
PORT_RANGE_END=8199
